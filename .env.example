# Copy this file to .env (or set these in your hosting panel)
# Never commit real secrets.

# Production
DB_DSN=mysql:host=YOUR_DB_HOST;dbname=YOUR_DB_NAME
DB_USER=YOUR_DB_USER
DB_PASS=YOUR_DB_PASSWORD

# Optional local overrides
DB_DSN_LOCAL=mysql:unix_socket=/tmp/my-mysql.sock;dbname=nsbm_market
DB_USER_LOCAL=root
DB_PASS_LOCAL=
