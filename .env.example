# Copy this file to .env (or set these in your hosting panel)
# Never commit real secrets.

# Local Development Credentials
DB_LOCAL_SOCKET=/opt/lampp/var/mysql/mysql.sock
DB_LOCAL_NAME=nsbm_market
DB_LOCAL_USER=root
DB_LOCAL_PASS=

# Production / Remote Credentials
DB_REMOTE_HOST=YOUR_DB_HOST
DB_REMOTE_NAME=YOUR_DB_NAME
DB_REMOTE_USER=YOUR_DB_USER
DB_REMOTE_PASS=YOUR_DB_PASSWORD
